# ==========================================================
#  PRODUCTION — pblog.ci/bal
#  Copier ce fichier en .env SUR LE SERVEUR puis remplir.
#  Ne jamais committer le vrai .env (il est dans .gitignore).
# ==========================================================

APP_NAME="Pigier's Élites Awards"
APP_ENV=production
APP_KEY=                      # généré sur le serveur : php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=Africa/Abidjan

# IMPORTANT : l'app est dans un sous-dossier /bal
APP_URL=https://pblog.ci/bal
ASSET_URL=https://pblog.ci/bal

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# --- Logs (production) ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Base de données MySQL de l'hébergement ---
# Sur cPanel, le nom de base et l'utilisateur ont un préfixe, ex : pblogci_bal
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=VOTRE_BASE
DB_USERNAME=VOTRE_USER
DB_PASSWORD=VOTRE_MOT_DE_PASSE

# MyISAM par défaut sur certains hébergeurs → on force InnoDB (déjà géré en config)
DB_ENGINE=InnoDB

# --- Sessions / cache / queue (simple, sans Redis) ---
SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/bal
SESSION_DOMAIN=pblog.ci

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# --- Anti double-inscription ---
REGISTRATION_BLOCK_DEVICE=true
REGISTRATION_BLOCK_IP=false

# --- Mail (optionnel ; 'log' = pas d'envoi réel) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@pblog.ci"
MAIL_FROM_NAME="${APP_NAME}"
